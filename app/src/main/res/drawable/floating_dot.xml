<?xml version="1.0" encoding="utf-8"?>
<!--
  Floating dot background: layered design
  Layer 1 – outer soft glow ring (12% opacity blue)
  Layer 2 – main gradient circle inset by 8dp, blue → cyan with subtle white stroke
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow halo -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#316dcef3" />
        </shape>
    </item>

    <!-- Main gradient circle -->
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:centerColor="#2196F3"
                android:endColor="#03A9F4"
                android:startColor="#1565C0"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- Inner highlight (top-left subtle gloss) -->
    <item
        android:bottom="28dp"
        android:left="12dp"
        android:right="28dp"
        android:top="12dp">
        <shape android:shape="oval">
            <solid android:color="#22FFFFFF" />
        </shape>
    </item>

</layer-list>