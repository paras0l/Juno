<?xml version="1.0" encoding="utf-8"?>
<!--
  Scan / OCR icon – four corner brackets + central scan line.
  Designed to sit on a dark/blue background (white strokes).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top-left bracket -->
    <path
        android:pathData="M7,3 L3,3 L3,7"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Top-right bracket -->
    <path
        android:pathData="M17,3 L21,3 L21,7"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Bottom-left bracket -->
    <path
        android:pathData="M7,21 L3,21 L3,17"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Bottom-right bracket -->
    <path
        android:pathData="M17,21 L21,21 L21,17"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Horizontal scan line -->
    <path
        android:pathData="M5,12 L19,12"
        android:strokeWidth="1.5"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#CCFFFFFF"
        android:strokeLineCap="round" />

</vector>
